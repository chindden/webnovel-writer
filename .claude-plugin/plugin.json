{
  "name": "webnovel-writer",
  "version": "5.0.0",
  "description": "Chinese webnovel writing assistant with anti-hallucination protocols (三大定律), cool-points strategy (爽点系统), and Strand Weave pacing control.",
  "license": "GPL-3.0",
  "author": {
    "name": "lcy"
  },
  "keywords": [
    "webnovel",
    "chinese",
    "writing",
    "网文",
    "小说",
    "workflow",
    "state",
    "git",
    "claude-code",
    "mcp"
  ],
  "commands": "./commands/",
  "skills": "./skills/",
  "agents": "./agents/",
  "mcp": {
    "server": "./mcp_server.py",
    "tools": [
      "webnovel-init",
      "webnovel-query",
      "webnovel-status",
      "webnovel-context"
    ],
    "resources": [
      "webnovel://skills/*",
      "webnovel://references/*"
    ]
  },
  "python": {
    "version": ">=3.8",
    "dependencies": [
      "pypinyin>=0.44.0",
      "filelock>=3.0.0",
      "aiohttp>=3.8.0"
    ]
  },
  "features": {
    "dual-agent-architecture": "Context Agent (读) + Data Agent (写)",
    "anti-hallucination": "三大定律：设定即物理、金手指追踪、叙事惯性",
    "cool-points": "爽点系统：类型多样化、密度监控、质量评估",
    "strand-weave": "Strand Weave：Quest/Fire/Constellation 三线平衡",
    "entity-management": "entities_v3 分组格式 + alias_index 一对多"
  }
}
